# One self-hosted play engine — env for docker-compose.engine.yml.
# Copy per engine (e.g. `cp engine.env.example alpha.engine.env`); *.engine.env is gitignored.
# EngineId/Token come from the admin UI: http://localhost:3001/Admin → Engines →
# "Register external engine" (set the board-size range to match the checkpoint).

# --- Credentials (required) ---
ENGINE_ID=
ENGINE_TOKEN=

# --- Checkpoint (required) — any .pt; the engine reads the net shape from the file itself ---
ENGINE_MODEL=./training-data/run2/checkpoints/best.pt

# --- Optional overrides (defaults shown) ---
# ENGINE_IMAGE=ghcr.io/nomi-y/neural-hex-engine:latest   # pin :cu121 / :sha-<commit> if you like
# ENGINE_WS=ws://backend:3001        # remote backend? use ws://<backend-host>:3001 (+ drop networks: block)
# ENGINE_DEVICE=cuda                 # cpu also works (drop the devices: block, use a :cpu image)
# ENGINE_SIMS=400                    # MCTS sims/move — higher = stronger & slower
# ENGINE_TEMPERATURE=0.0             # 0 = strongest; >0 = move variety
