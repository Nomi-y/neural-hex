# Credentials + weights for the self-hosted play engines (docker-compose.engines.yml).
# Copy to .env.engines (gitignored) and fill in. Each engine's Id/Token come from the admin UI:
# http://localhost:3001/Admin → Engines tab → "Register external engine".

# --- Engine 1 ---
ENGINE1_ID=
ENGINE1_TOKEN=
ENGINE1_MODEL=./training-data/run1/checkpoints/best.pt

# --- Engine 2 ---
ENGINE2_ID=
ENGINE2_TOKEN=
ENGINE2_MODEL=./training-data/run2/checkpoints/best.pt

# MCTS simulations per move for every engine (lower = faster/weaker). Optional.
ENGINE_SIMS=400

# Engine image to pull (optional). Pin a wheel/sha for a mixed fleet, e.g.
# ghcr.io/nomi-y/neural-hex-engine:cu121  (Turing→Ada)  ·  :cu128  (Blackwell)  ·  :sha-<commit>
# ENGINE_IMAGE=ghcr.io/nomi-y/neural-hex-engine:latest
