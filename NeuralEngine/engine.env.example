# Copy to engine.env (gitignored) and fill in your external-engine credentials, obtained when you
# register the engine on the backend (POST /Admin/Api/Engines/External). run_engine.sh loads this.
ENGINE_ID=your-engine-id
ENGINE_TOKEN=your-engine-token

# Backend WebSocket endpoint (default: the local stack's backend port).
ENGINE_WS=ws://localhost:3001
