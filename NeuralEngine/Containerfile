# NeuralEngine — self-training Hex engine container
#
# Build:  ./build_container.sh
#         (reads hyperparams.toml, bakes it in, optionally applies a preset)
#
# Run (CPU):    docker run -v ./checkpoints:/app/checkpoints -v ./logs:/app/logs neuralengine
# Run (GPU):    docker run --gpus all -v ./checkpoints:/app/checkpoints -v ./logs:/app/logs neuralengine
#
# The hyperparams.toml IS the configuration — edit it before building.
# You can still override any value at runtime with -e, e.g.:
#   docker run -e TRAIN_HOURS=12 -v ./checkpoints:/app/checkpoints neuralengine
#
# Checkpoints and logs land in bind-mounted directories so they persist across restarts.

FROM docker.io/python:3.12-slim
WORKDIR /app

# System deps for PyTorch (libgomp is needed at runtime).
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Install non-torch dependencies first (lightweight).
# torch is installed separately below so we can choose CPU vs CUDA.
COPY requirements.txt .
RUN pip install --no-cache-dir numpy websockets

# ── Torch installation ───────────────────────────────────────────────────────
# Default: CPU-only torch (--index-url cpu).  With --cuda, install the default
# PyPI torch wheel which already bundles the right CUDA libraries for the host.
ARG CUDA_BUILD="false"
RUN if [ "${CUDA_BUILD}" = "true" ]; then \
      pip install --no-cache-dir --default-timeout=600 torch; \
    else \
      pip install --no-cache-dir --default-timeout=600 torch --index-url https://download.pytorch.org/whl/cpu; \
    fi

# Copy the project source *after* pip so code changes don't reinstall deps.
COPY . .

# Smoke-test the container build to catch config/code issues early.
RUN python smoke_test.py

# Default command: launch training directly (hyperparams.toml is the config).
CMD ["python", "-m", "train.train"]
