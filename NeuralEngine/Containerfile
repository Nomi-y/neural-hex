# NeuralEngine — self-training Hex engine container
#
# Build:  ./build_container.sh
#         (reads hyperparams.toml, bakes it in, optionally applies a preset)
#
# Run (CPU):    docker run -v ./checkpoints:/workspace/checkpoints -v ./logs:/workspace/logs neuralengine
# Run (GPU):    docker run --gpus all -v ./checkpoints:/workspace/checkpoints -v ./logs:/workspace/logs neuralengine
#
# The hyperparams.toml IS the configuration — edit it before building.
# You can still override any value at runtime with -e, e.g.:
#   docker run -e TRAIN_HOURS=12 -v ./checkpoints:/workspace/checkpoints neuralengine
#
# Checkpoints and logs default to /workspace (see ENV below) so a run persists to a mounted
# network volume (e.g. RunPod /workspace) with no flags — bind-mount or attach a volume there.

FROM docker.io/python:3.12-slim
WORKDIR /app

# System deps for PyTorch (libgomp is needed at runtime) and Triton JIT
# (torch.compile needs a C compiler + standard headers to build CUDA kernels).
# libc6-dev provides stdlib.h / stdio.h — the slim image strips them.
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
    libgomp1 \
    gcc \
    libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# Install non-torch dependencies first (lightweight).
# torch is installed separately below so we can choose CPU vs CUDA.
COPY requirements.txt .
RUN pip install --no-cache-dir numpy websockets

# ── Torch installation ───────────────────────────────────────────────────────
# Default: CPU-only torch (--index-url cpu).  With --cuda, install a torch wheel
# whose bundled CUDA runtime matches the host GPU driver.
#
# CUDA_WHEEL picks that runtime. A driver NEWER than the wheel always runs it
# (backward compatibility); a wheel newer than the driver makes torch decide the
# driver is "too old", disable CUDA, and silently run on CPU. So on a fleet with
# varying/unknown drivers (e.g. RunPod, where the driver can change between runs
# on the same GPU) pin the LOWEST CUDA that supports your GPU arch — then every
# host driver is >= the wheel and CUDA just works.
#   cu121  needs driver CUDA >= 12.1 (R530+)  — safe default across the fleet
#   cu118  needs driver CUDA >= 11.8 (R520+)  — ultra-safe, older GPUs
#   cu128  needs driver CUDA >= 12.8 (R570+)  — REQUIRED for Blackwell (RTX 5090/B200)
ARG CUDA_BUILD="false"
ARG CUDA_WHEEL="cu121"
RUN if [ "${CUDA_BUILD}" = "true" ]; then \
      pip install --no-cache-dir --default-timeout=600 torch --index-url https://download.pytorch.org/whl/${CUDA_WHEEL}; \
    else \
      pip install --no-cache-dir --default-timeout=600 torch --index-url https://download.pytorch.org/whl/cpu; \
    fi

# Copy the project source *after* pip so code changes don't reinstall deps.
COPY . .

# Smoke-test the container build to catch config/code issues early.
RUN python smoke_test.py
# Verify the GPU inference server matches a local evaluator (runs on CPU at build time).
RUN python test_inference_server.py
# Verify the logging + hardware-monitor plumbing.
RUN python test_logging.py

# ── Build-time Triton toolchain check ──────────────────────────────────────
# torch.compile (reduce-overhead) JIT-compiles CUDA kernels via Triton, which
# calls gcc to build a small C utility.  The slim Python image ships gcc but
# strips the C standard library headers (libc6-dev).  If that happens, compile
# silently falls back to eager mode at runtime (the warmup catches it, but
# you lose the 1.5–2× training speedup).  This RUN fails the Docker build NOW
# if gcc or stdlib.h is missing — the image never reaches GHCR broken.
RUN echo '#include <stdlib.h>' | gcc -x c -c - -o /dev/null

# ── Persistent output defaults ─────────────────────────────────────────────
# Checkpoints and logs default to /workspace so a deployment writes to a mounted network volume
# (e.g. RunPod's /workspace, which persists after the pod stops) WITHOUT needing -e every time —
# forgetting the override once would otherwise write to the container's ephemeral disk and lose the
# run. Set AFTER the build guards so the build never creates /workspace. A `docker run -e
# CHECKPOINT_DIR=… / -e LOG_DIR=…` still wins (env overrides ENV); the app makedirs them at startup.
ENV CHECKPOINT_DIR=/workspace/checkpoints \
    LOG_DIR=/workspace/logs

# ── Container role ──────────────────────────────────────────────────────────
# One image, two roles. Default "train" leaves the training image unchanged; the
# engine image is built with --build-arg HEX_ROLE=engine so it runs the play/analysis
# engine by default (entrypoint.sh dispatches on this). Still overridable at runtime:
#   docker run -e HEX_ROLE=engine ...   (run the engine from a training image, or vice versa)
ARG HEX_ROLE=train
ENV HEX_ROLE=${HEX_ROLE}

# Entrypoint script logs GPU info, then launches the role's process (train: +CUDA MPS).
COPY entrypoint.sh .
RUN chmod +x entrypoint.sh
CMD ["./entrypoint.sh"]
